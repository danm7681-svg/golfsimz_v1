@page "/"
@namespace golfsimz_v1
@inject IJSRuntime JSRuntime

<div style="background-color: #111; color: #fff; font-family: sans-serif; min-height: 100vh; display: flex; flex-direction: column;">
    
    <div style="flex: 1; position: relative; min-height: 400px; background: #0a141d;">
        <canvas id="canvas3d" style="width: 100%; height: 100%; display: block;"></canvas>
        
        <div style="position: absolute; top: 20px; left: 20px; background: rgba(0,0,0,0.85); padding: 16px; border-radius: 8px; border: 1px solid rgba(255,255,255,0.1); width: 260px; backdrop-filter: blur(6px); z-index: 10;">
            <h3 style="margin: 0 0 12px 0; font-size: 13px; text-transform: uppercase; color: #aaa; letter-spacing: 1px;">Calculated Flight Output</h3>
            <div style="display: flex; flex-direction: column; gap: 8px; margin-bottom: 14px;">
                <div style="display: flex; justify-content: space-between;"><span style="color: #aaa;">Carry Distance</span><strong style="color: #ff8c00; font-size: 18px;">@CarryDistanceYds.ToString("F1") yds</strong></div>
                <div style="display: flex; justify-content: space-between;"><span style="color: #aaa;">Apex Height</span><strong>@ApexHeightFt.ToString("F1") ft</strong></div>
                <div style="display: flex; justify-content: space-between;"><span style="color: #aaa;">Hang Time</span><strong>@TotalHangTime.ToString("F2") s</strong></div>
                <div style="display: flex; justify-content: space-between;"><span style="color: #aaa;">Offline Deviation</span><strong style="color: @(OfflineYds < 0 ? "#ff4444" : "#44ff44");">@Math.Abs(OfflineYds).ToString("F1") @(OfflineYds < 0 ? "Yds Left" : "Yds Right")</strong></div>
            </div>
            <div style="display: flex; gap: 10px;">
                <button @onclick="CalculateFlight" style="flex: 1; background: #ff8c00; border: 0; padding: 12px; border-radius: 4px; color: white; font-weight: bold; cursor: pointer; text-transform: uppercase; font-size: 12px; letter-spacing: 0.5px;">Fire Simulation</button>
                <button @onclick="ResetSession" style="background: #333; border: 0; padding: 12px; border-radius: 4px; color: white; cursor: pointer; font-size: 12px;">RESET</button>
            </div>
        </div>
    </div>

    <div style="background: #181818; padding: 20px; border-top: 2px solid #282828; display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 20px;">
        
        <div>
            <div style="display: flex; justify-content: space-between; margin-bottom: 6px;">
                <label style="font-size: 11px; color: #aaa; font-weight: bold; uppercase;">BALL SPEED (MPH)</label>
                <input type="number" step="0.1" @bind="BallSpeed" style="width: 70px; background: #222; border: 1px solid #444; color: #fff; text-align: right; padding: 2px 4px; border-radius: 4px;" />
            </div>
            <input type="range" min="40" max="200" step="1" @bind="BallSpeed" @bind:event="oninput" style="width: 100%; accent-color: #ff8c00;" />
        </div>

        <div>
            <div style="display: flex; justify-content: space-between; margin-bottom: 6px;">
                <label style="font-size: 11px; color: #aaa; font-weight: bold; uppercase;">LAUNCH ANGLE (°)</label>
                <input type="number" step="0.1" @bind="LaunchAngle" style="width: 70px; background: #222; border: 1px solid #444; color: #fff; text-align: right; padding: 2px 4px; border-radius: 4px;" />
            </div>
            <input type="range" min="5" max="50" step="0.5" @bind="LaunchAngle" @bind:event="oninput" style="width: 100%; accent-color: #ff8c00;" />
        </div>

        <div>
            <div style="display: flex; justify-content: space-between; margin-bottom: 6px;">
                <label style="font-size: 11px; color: #aaa; font-weight: bold; uppercase;">BACKSPIN (RPM)</label>
                <input type="number" step="50" @bind="Backspin" style="width: 70px; background: #222; border: 1px solid #444; color: #fff; text-align: right; padding: 2px 4px; border-radius: 4px;" />
            </div>
            <input type="range" min="1000" max="12000" step="100" @bind="Backspin" @bind:event="oninput" style="width: 100%; accent-color: #ff8c00;" />
        </div>

        <div>
            <div style="display: flex; justify-content: space-between; margin-bottom: 6px;">
                <label style="font-size: 11px; color: #aaa; font-weight: bold; uppercase;">SIDESPIN (RPM)</label>
                <input type="number" step="50" @bind="Sidespin" style="width: 70px; background: #222; border: 1px solid #444; color: #fff; text-align: right; padding: 2px 4px; border-radius: 4px;" />
            </div>
            <input type="range" min="-4000" max="4000" step="100" @bind="Sidespin" @bind:event="oninput" style="width: 100%; accent-color: #ff8c00;" />
        </div>

        <div>
            <div style="display: flex; justify-content: space-between; margin-bottom: 6px;">
                <label style="font-size: 11px; color: #aaa; font-weight: bold; uppercase;">LAUNCH DIRECTION (°)</label>
                <input type="number" step="0.1" @bind="SideAngle" style="width: 70px; background: #222; border: 1px solid #444; color: #fff; text-align: right; padding: 2px 4px; border-radius: 4px;" />
            </div>
            <input type="range" min="-10" max="10" step="0.5" @bind="SideAngle" @bind:event="oninput" style="width: 100%; accent-color: #ff8c00;" />
        </div>

    </div>

    @if (TelemetrySteps != null && TelemetrySteps.Count > 0)
    {
        <div style="background: #111; padding: 20px; border-top: 1px solid #333; max-height: 250px; overflow-y: scroll;">
            <h4 style="margin: 0 0 10px 0; font-size: 12px; color: #ff8c00; letter-spacing: 1px; text-transform: uppercase;">Aero Engine Step-by-Step Telemetry Log</h4>
            <table style="width: 100%; border-collapse: collapse; font-size: 12px; font-family: monospace; text-align: left;">
                <thead>
                    <tr style="color: #888; border-bottom: 1px solid #222;">
                        <th style="padding: 6px 0;">Time (s)</th>
                        <th>Distance (Yds)</th>
                        <th>Altitude (Ft)</th>
                        <th>Offline Axis (Yds)</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var step in TelemetrySteps)
                    {
                        <tr style="border-bottom: 1px solid #1a1a1a; color: #ddd;">
                            <td style="padding: 4px 0;">@step.Time.ToString("F3")</td>
                            <td>@step.DownrangeYds.ToString("F1")</td>
                            <td>@step.AltitudeFt.ToString("F1")</td>
                            <td style="color: @(step.OfflineYds < 0 ? "#ff5555" : step.OfflineYds > 0 ? "#55ff55" : "#ddd");">@step.OfflineYds.ToString("F2")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private float BallSpeed { get; set; } = 135f;
    private float LaunchAngle { get; set; } = 14.5f;
    private float Backspin { get; set; } = 2800f;
    private float Sidespin { get; set; } = 0f;
    private float SideAngle { get; set; } = 0f;

    private float CarryDistanceYds { get; set; } = 0f;
    private float ApexHeightFt { get; set; } = 0f;
    private float TotalHangTime { get; set; } = 0f;
    private float OfflineYds { get; set; } = 0f;

    private List<TrajectoryPoint> TelemetrySteps { get; set; } = new List<TrajectoryPoint>();
    private GolfBallEngine engine = new GolfBallEngine();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("init3DTracer", "canvas3d");
        }
    }

    private async Task CalculateFlight()
    {
        TelemetrySteps = engine.SimulateShot(BallSpeed, LaunchAngle, SideAngle, Backspin, Sidespin);
        CarryDistanceYds = engine.CarryDistanceYds;
        ApexHeightFt = engine.ApexHeightFt;
        TotalHangTime = engine.TotalHangTime;
        OfflineYds = engine.OfflineYds;

        var json = System.Text.Json.JsonSerializer.Serialize(TelemetrySteps);
        await JSRuntime.InvokeVoidAsync("update3DTracer", json);
    }

    private async Task ResetSession()
    {
        CarryDistanceYds = 0f;
        ApexHeightFt = 0f;
        TotalHangTime = 0f;
        OfflineYds = 0f;
        TelemetrySteps.Clear();
        await JSRuntime.InvokeVoidAsync("update3DTracer", "[]");
    }
}
