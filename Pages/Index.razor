@page "/"
@using golfsimz_v1
@inject IJSRuntime JSRuntime

<div class="app-container">
    <!-- 3D Viewport -->
    <div class="viewport" style="flex:1; position:relative; background:#0a0a1a; overflow:hidden;">
        <canvas id="threeCanvas" style="width:100%; height:100%; display:block;"></canvas>
        
        <!-- Birdseye View (Larger, Right Side) -->
        <div class="birdseye-overlay">
            <canvas id="birdseyeCanvas" width="320" height="420"></canvas>
        </div>
    </div>

    <!-- Data Panel -->
    <div class="data-panel">
        <div class="metric">
            <span class="label">CARRY</span>
            <span class="value">@(CarryDistanceYds.ToString("F1"))</span>
            <span class="unit">yds</span>
        </div>
        <div class="metric">
            <span class="label">TOTAL</span>
            <span class="value">@((CarryDistanceYds + 10).ToString("F1"))</span>
            <span class="unit">yds</span>
        </div>
        <div class="metric">
            <span class="label">BALL SPEED</span>
            <span class="value">@(BallSpeed.ToString("F0"))</span>
            <span class="unit">mph</span>
        </div>
        <div class="metric">
            <span class="label">LAUNCH ANG.</span>
            <span class="value">@(LaunchAngle.ToString("F1"))</span>
            <span class="unit">deg</span>
        </div>
        <div class="metric">
            <span class="label">HEIGHT</span>
            <span class="value">@(ApexHeightFt.ToString("F0"))</span>
            <span class="unit">ft</span>
        </div>
        <div class="metric">
            <span class="label">LANDING ANGLE</span>
            <span class="value">@(LandingAngleDeg.ToString("F0"))</span>
            <span class="unit">deg</span>
        </div>
    </div>

    <!-- Editable Tiles -->
    <div class="tiles-bar">
        <div class="tile">
            <span class="tile-label">CLUB</span>
            <input @bind="Club" class="tile-input" />
        </div>
        <div class="tile">
            <span class="tile-label">BALL SPEED</span>
            <input @bind="BallSpeed" type="number" class="tile-input" />
        </div>
        <div class="tile">
            <span class="tile-label">LAUNCH</span>
            <input @bind="LaunchAngle" type="number" class="tile-input" />
        </div>
        <div class="tile">
            <span class="tile-label">BACKSPIN</span>
            <input @bind="Backspin" type="number" class="tile-input" />
        </div>
        <div class="tile">
            <span class="tile-label">SIDESPIN</span>
            <input @bind="Sidespin" type="number" class="tile-input" />
        </div>
        <div class="tile">
            <span class="tile-label">SIDE ANGLE</span>
            <input @bind="SideAngle" type="number" class="tile-input" />
        </div>
        <button @onclick="CalculateFlight" class="run-btn">▶</button>
    </div>
</div>

@code {
    private string Club { get; set; } = "7 Iron";
    private float BallSpeed { get; set; } = 120f;
    private float LaunchAngle { get; set; } = 14.5f;
    private float Backspin { get; set; } = 2800f;
    private float Sidespin { get; set; } = 0f;
    private float SideAngle { get; set; } = 0f;

    private float CarryDistanceYds { get; set; }
    private float ApexHeightFt { get; set; }
    private float TotalHangTime { get; set; }
    private float OfflineYds { get; set; }
    private float LandingAngleDeg { get; set; }

    private List<TrajectoryPoint> TrajectoryPoints { get; set; } = new();
    private GolfBallEngine engine = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Task.Delay(300);
            await JSRuntime.InvokeVoidAsync("init3DTracer", "threeCanvas");
            await Task.Delay(100);
            CalculateFlight();
        }
    }

    private async void CalculateFlight()
    {
        TrajectoryPoints = engine.SimulateShot(BallSpeed, LaunchAngle, SideAngle, Backspin, Sidespin);
        CarryDistanceYds = engine.CarryDistanceYds;
        ApexHeightFt = engine.ApexHeightFt;
        TotalHangTime = engine.TotalHangTime;
        OfflineYds = engine.OfflineYds;
        LandingAngleDeg = engine.LandingAngleDeg;

        var json = System.Text.Json.JsonSerializer.Serialize(TrajectoryPoints);
        await JSRuntime.InvokeVoidAsync("update3DTracer", json);
        await JSRuntime.InvokeVoidAsync("drawBirdseye", "birdseyeCanvas", json);

        StateHasChanged();
    }
}