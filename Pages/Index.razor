@page "/"
@using GolfsimzV1
@inject IJSRuntime JS

<PageTitle>Golfsimz V1 - Launch Monitor</PageTitle>

<div class="app-container">
    <!-- Header -->
    <header class="header">
        <h1>Golfsimz V1</h1>
        <div class="status">
            <span class="status-dot ready"></span>
            <span>Engine Ready</span>
        </div>
    </header>

    <!-- 3D Canvas -->
    <div class="canvas-container">
        <canvas id="three-canvas"></canvas>
        <div class="view-toggles">
            <button class="view-toggle active" @onclick="@(() => ChangeView("perspective"))">Perspective</button>
            <button class="view-toggle" @onclick="@(() => ChangeView("birdseye"))">Top Down</button>
            <button class="view-toggle" @onclick="@(() => ChangeView("behind"))">Behind Ball</button>
        </div>
    </div>

    <!-- Control Panel -->
    <div class="control-panel">
        <!-- Input Sliders -->
        <div class="input-group">
            <label>Ball Speed (mph)</label>
            <input type="range" min="50" max="200" step="1" 
                   @bind-value="ballSpeed" @bind-value:event="oninput" />
            <span class="value-display">@ballSpeed mph</span>
        </div>

        <div class="input-row">
            <div class="input-group">
                <label>Launch Angle (&deg;)</label>
                <input type="range" min="5" max="40" step="0.5" 
                       @bind-value="launchAngle" @bind-value:event="oninput" />
                <span class="value-display">@launchAngle&deg;</span>
            </div>
            <div class="input-group">
                <label>Spin Rate (rpm)</label>
                <input type="range" min="800" max="6000" step="50" 
                       @bind-value="spinRate" @bind-value:event="oninput" />
                <span class="value-display">@spinRate rpm</span>
            </div>
        </div>

        <button class="btn btn-primary" @onclick="SimulateShot">
            🚀 Launch Ball
        </button>

        <!-- Results -->
        @if (result != null)
        {
            <div class="data-grid">
                <div class="data-card">
                    <h3>Carry Distance</h3>
                    <span class="value">@result.Carry.ToString("F1")</span>
                    <span class="unit">yds</span>
                </div>
                <div class="data-card">
                    <h3>Apex Height</h3>
                    <span class="value">@result.Apex.ToString("F1")</span>
                    <span class="unit">ft</span>
                </div>
                <div class="data-card">
                    <h3>Flight Time</h3>
                    <span class="value">@result.FlightTime.ToString("F2")</span>
                    <span class="unit">s</span>
                </div>
                <div class="data-card">
                    <h3>Lateral</h3>
                    @{
                        var latColor = result.LateralDeviation < 0 ? "#ff4455" : "#00ff88";
                        var latDir = result.LateralDeviation < 0 ? "L " : "R ";
                    }
                    <span class="value" style="color: @latColor">
                        @latDir@Math.Abs(result.LateralDeviation).ToString("F1")
                    </span>
                    <span class="unit">yds</span>
                </div>
            </div>

            <!-- Birdseye View -->
            <div class="birdseye-container">
                <canvas id="birdseye-canvas"></canvas>
            </div>
        }
    </div>
</div>

@code {
    private double ballSpeed = 150;
    private double launchAngle = 12;
    private double spinRate = 2500;
    private TrajectoryResult? result;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("trajectoryPlot.initializeVisualization");
        }
    }

    private async Task SimulateShot()
    {
        result = GolfBallEngine.CalculateTrajectory(
            ballSpeedMph: ballSpeed,
            launchAngleDeg: launchAngle,
            spinRateRpm: spinRate
        );

        // Send to JavaScript for visualization
        var jsonData = new
        {
            trajectory = result.Trajectory.Select(p => new { 
                x = p.X / 0.9144, 
                y = p.Y / 0.3048, 
                z = p.Z / 0.9144 
            }),
            carry = result.Carry,
            lateralDeviation = result.LateralDeviation
        };

        await JS.InvokeVoidAsync("trajectoryPlot.displayTrajectory", jsonData);
        StateHasChanged();
    }

    private async Task ChangeView(string view)
    {
        await JS.InvokeVoidAsync("trajectoryPlot.changeView", view);
    }
}
