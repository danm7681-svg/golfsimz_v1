@page "/"
@using GolfsimzV1
@inject IJSRuntime JS

<PageTitle>Golfsimz V1 - Launch Monitor</PageTitle>

<div class="app-container">
    <header class="header">
        <h1>Golfsimz V1</h1>
        <div class="status">
            <span class="status-dot ready"></span>
            <span>Engine Ready</span>
        </div>
    </header>

    <div class="canvas-container">
        <canvas id="three-canvas"></canvas>
        <div class="view-toggles">
            <button class="view-toggle active" @onclick="SetPerspectiveView">Perspective</button>
            <button class="view-toggle" @onclick="SetBirdseyeView">Top Down</button>
            <button class="view-toggle" @onclick="SetBehindBallView">Behind Ball</button>
        </div>
    </div>

    <div class="control-panel">
        
        <div class="tile-row">
            <!-- Ball Speed -->
            <div class="edit-tile" @onclick="StartEditBallSpeed">
                @if (editingField == "ballSpeed")
                {
                    <input type="number" 
                           class="tile-input" 
                           @bind-value="ballSpeedInput"
                           @bind-value:event="oninput"
                           @onkeydown="OnKeyDownBallSpeed"
                           @onblur="StopEditing"
                           autofocus />
                }
                else
                {
                    <span class="tile-value">@ballSpeed</span>
                }
                <span class="tile-label">Ball Speed</span>
                <span class="tile-unit">mph</span>
            </div>

            <!-- Launch Angle -->
            <div class="edit-tile" @onclick="StartEditLaunchAngle">
                @if (editingField == "launchAngle")
                {
                    <input type="number" 
                           class="tile-input" 
                           @bind-value="launchAngleInput"
                           @bind-value:event="oninput"
                           @onkeydown="OnKeyDownLaunchAngle"
                           @onblur="StopEditing"
                           autofocus />
                }
                else
                {
                    <span class="tile-value">@launchAngle.ToString("F1")</span>
                }
                <span class="tile-label">Launch Angle</span>
                <span class="tile-unit">°</span>
            </div>

            <!-- Spin Rate -->
            <div class="edit-tile" @onclick="StartEditSpinRate">
                @if (editingField == "spinRate")
                {
                    <input type="number" 
                           class="tile-input" 
                           @bind-value="spinRateInput"
                           @bind-value:event="oninput"
                           @onkeydown="OnKeyDownSpinRate"
                           @onblur="StopEditing"
                           autofocus />
                }
                else
                {
                    <span class="tile-value">@spinRate</span>
                }
                <span class="tile-label">Spin Rate</span>
                <span class="tile-unit">rpm</span>
            </div>
        </div>

        <div class="preset-row">
            <button class="preset-btn" @onclick="SetPresetDriver">Driver</button>
            <button class="preset-btn" @onclick="SetPreset7Iron">7 Iron</button>
            <button class="preset-btn" @onclick="SetPresetPW">PW</button>
        </div>

        <button class="btn btn-primary" @onclick="SimulateShot">
            🚀 Launch Ball
        </button>

        @if (result != null)
        {
            <div class="data-grid">
                <div class="data-card">
                    <h3>Carry Distance</h3>
                    <span class="value">@result.Carry.ToString("F1")</span>
                    <span class="unit">yds</span>
                </div>
                <div class="data-card">
                    <h3>Apex Height</h3>
                    <span class="value">@result.Apex.ToString("F1")</span>
                    <span class="unit">ft</span>
                </div>
                <div class="data-card">
                    <h3>Flight Time</h3>
                    <span class="value">@result.FlightTime.ToString("F2")</span>
                    <span class="unit">s</span>
                </div>
                <div class="data-card">
                    <h3>Lateral</h3>
                    <span class="value" style="color: @(result.LateralDeviation < 0 ? "#ff4455" : "#00ff88")">
                        @(result.LateralDeviation < 0 ? "L " : "R ")@Math.Abs(result.LateralDeviation).ToString("F1")
                    </span>
                    <span class="unit">yds</span>
                </div>
            </div>

            <div class="birdseye-container">
                <canvas id="birdseye-canvas"></canvas>
            </div>
        }
    </div>
</div>

@code {
    private double ballSpeed = 150;
    private double launchAngle = 12;
    private double spinRate = 2500;

    private string ballSpeedInput = "150";
    private string launchAngleInput = "12";
    private string spinRateInput = "2500";

    private string? editingField = null;

    private TrajectoryResult? result;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("trajectoryPlot.initializeVisualization");
        }
    }

    // ---- View Change Methods ----
    private async Task SetPerspectiveView() => await ChangeView("perspective");
    private async Task SetBirdseyeView() => await ChangeView("birdseye");
    private async Task SetBehindBallView() => await ChangeView("behind");

    private async Task ChangeView(string view)
    {
        await JS.InvokeVoidAsync("trajectoryPlot.changeView", view);
    }

    // ---- Start Editing Methods ----
    private void StartEditBallSpeed()
    {
        editingField = "ballSpeed";
        ballSpeedInput = ballSpeed.ToString();
    }

    private void StartEditLaunchAngle()
    {
        editingField = "launchAngle";
        launchAngleInput = launchAngle.ToString("F1");
    }

    private void StartEditSpinRate()
    {
        editingField = "spinRate";
        spinRateInput = spinRate.ToString();
    }

    // ---- Key Down Methods ----
    private void OnKeyDownBallSpeed(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") StopEditing();
    }

    private void OnKeyDownLaunchAngle(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") StopEditing();
    }

    private void OnKeyDownSpinRate(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") StopEditing();
    }

    // ---- Stop Editing ----
    private void StopEditing()
    {
        if (editingField == "ballSpeed" && double.TryParse(ballSpeedInput, out var bs))
            ballSpeed = Math.Clamp(bs, 50, 200);
        else if (editingField == "launchAngle" && double.TryParse(launchAngleInput, out var la))
            launchAngle = Math.Clamp(la, 5, 40);
        else if (editingField == "spinRate" && double.TryParse(spinRateInput, out var sr))
            spinRate = Math.Clamp(sr, 800, 6000);

        editingField = null;
    }

    // ---- Presets ----
    private void SetPresetDriver() => SetPreset(165, 10.5, 2800);
    private void SetPreset7Iron() => SetPreset(140, 18, 5000);
    private void SetPresetPW() => SetPreset(110, 28, 7000);

    private void SetPreset(double speed, double angle, double spin)
    {
        ballSpeed = speed;
        launchAngle = angle;
        spinRate = spin;
        editingField = null;
    }

    // ---- Simulate ----
    private async Task SimulateShot()
    {
        if (editingField != null)
            StopEditing();

        result = GolfBallEngine.CalculateTrajectory(
            ballSpeedMph: ballSpeed,
            launchAngleDeg: launchAngle,
            spinRateRpm: spinRate
        );

        var jsonData = new
        {
            trajectory = result.Trajectory.Select(p => new {
                x = p.X / 0.9144,
                y = p.Y / 0.3048,
                z = p.Z / 0.9144
            }),
            carry = result.Carry,
            lateralDeviation = result.LateralDeviation
        };

        await JS.InvokeVoidAsync("trajectoryPlot.displayTrajectory", jsonData);
        StateHasChanged();
    }
}
